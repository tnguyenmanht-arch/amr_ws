<?xml version="1.0"?>
<robot name="amr_ackermann" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ═══════════════════════════════════════════════════════════════
       AMR Ackermann Robot — URDF/Xacro
       Hardware: Jetson Orin Nano + STM32F446RE
       Điều chỉnh kích thước theo khung xe thực tế
  ═══════════════════════════════════════════════════════════════ -->

  <!-- ─── Tham số kích thước (đơn vị: mét) ─────────────────────── -->
  <!-- CẦN ĐIỀU CHỈNH theo kích thước khung xe thực tế -->
  <xacro:property name="base_length"   value="0.297"/> <!-- chiều dài chassis (không tính bánh) -->
  <xacro:property name="base_width"    value="0.158"/> <!-- chiều rộng khung chassis thật (không gồm bánh) -->
  <xacro:property name="base_height"   value="0.062"/> <!-- chiều cao chassis (không tính bánh) -->
  <xacro:property name="ground_clearance" value="0.022"/> <!-- mặt đất → mặt dưới khung gầm -->
  <xacro:property name="wheel_radius"  value="0.05"/>  <!-- bán kính bánh (đường kính 100mm → r=50mm) -->
  <xacro:property name="wheel_width"   value="0.029"/> <!-- bề rộng bánh -->
  <xacro:property name="wheelbase"     value="0.21"/>  <!-- khoảng cách trục trước-sau -->
  <xacro:property name="track_width"   value="0.217"/> <!-- khoảng cách 2 tâm bánh ngang (tâm→tâm) -->
  <!-- Khoảng trống lọt lòng giữa 2 mặt trong của 2 bánh (dẫn xuất) = 0.188m -->
  <xacro:property name="wheel_inner_gap" value="${track_width - wheel_width}"/>
  <!-- z của base_link so với base_footprint = ground_clearance + chassis_height/2 = 0.053m -->
  <xacro:property name="base_link_z" value="${ground_clearance + base_height/2}"/>

  <!-- ─── Materials ─────────────────────────────────────────────── -->
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="light_grey">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.0 0.4 0.8 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <!-- ─── Base footprint ────────────────────────────────────────── -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${base_link_z}" rpy="0 0 0"/>
  </joint>

  <!-- ─── Base link (chassis) ───────────────────────────────────── -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <!-- Hộp đặc m=2kg, L=0.297 W=0.158 H=0.062: I=1/12·m·(a²+b²) -->
      <inertia ixx="0.004801" ixy="0" ixz="0"
               iyy="0.015342" iyz="0"
               izz="0.018862"/>
    </inertial>
  </link>

  <!-- ─── Wheel macro ───────────────────────────────────────────── -->
  <xacro:macro name="wheel" params="name x y mirrored">
    <link name="${name}_wheel">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <material name="black"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      </collision>
      <inertial>
        <mass value="0.15"/>
        <!-- Trụ đặc r=0.05 h=0.029, trục quay Y: iyy=½mr², ixx=izz=1/12·m·(3r²+h²) -->
        <inertia ixx="0.0001043" ixy="0.0" ixz="0.0"
                 iyy="0.0001875" iyz="0.0"
                 izz="0.0001043"/>
      </inertial>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}_wheel"/>
      <!-- z = wheel_radius - base_link_z = 0.05 - 0.053 = -0.003m (tâm bánh hơi thấp hơn tâm chassis) -->
      <origin xyz="${x} ${y} ${wheel_radius - base_link_z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- Bánh sau dẫn động (JGB37-520) -->
  <xacro:wheel name="rear_left"
    x="${-wheelbase/2}" y="${track_width/2}"  mirrored="0"/>
  <xacro:wheel name="rear_right"
    x="${-wheelbase/2}" y="${-track_width/2}" mirrored="1"/>

  <!-- Bánh trước lái (HTS-20H) — dùng fixed joint, servo tính riêng -->
  <xacro:wheel name="front_left"
    x="${wheelbase/2}"  y="${track_width/2}"  mirrored="0"/>
  <xacro:wheel name="front_right"
    x="${wheelbase/2}"  y="${-track_width/2}" mirrored="1"/>

  <!-- ─── LiDAR frame ───────────────────────────────────────────── -->
  <!-- CẦN ĐIỀU CHỈNH vị trí gắn LiDAR trên xe thực tế -->
  <link name="laser_frame">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.06"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="laser_frame"/>
    <!-- Điều chỉnh xyz theo vị trí thực tế của RPLidar trên xe -->
    <origin xyz="0.10 0 0.06" rpy="0 0 0"/>
  </joint>

  <!-- ─── Camera frame ──────────────────────────────────────────── -->
  <!-- CẦN ĐIỀU CHỈNH vị trí gắn camera IMX-219 -->
  <link name="camera_frame">
    <visual>
      <geometry>
        <box size="0.025 0.025 0.020"/>
      </geometry>
      <material name="light_grey"/>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_frame"/>
    <!-- Điều chỉnh xyz: camera thường gắn phía trước, hướng xuống hoặc thẳng -->
    <origin xyz="0.12 0 0.05" rpy="0 0.3 0"/>
  </joint>

  <!-- Frame optical của camera (ROS convention: z-forward, x-right, y-down) -->
  <link name="camera_optical_frame"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_frame"/>
    <child  link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

</robot>

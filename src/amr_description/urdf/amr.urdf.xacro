<?xml version="1.0"?>
<robot name="amr_ackermann" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ═══════════════════════════════════════════════════════════════
       AMR Ackermann Robot — URDF/Xacro
       Hardware: Jetson Orin Nano + STM32F446RE
  ═══════════════════════════════════════════════════════════════ -->

  <xacro:include filename="$(find amr_description)/urdf/inertial_macros.xacro"/>
  <xacro:include filename="$(find amr_description)/urdf/amr_core.xacro"/>
  <xacro:include filename="$(find amr_description)/urdf/lidar.xacro"/>
  <xacro:include filename="$(find amr_description)/urdf/camera.xacro"/>
  <xacro:include filename="$(find amr_description)/urdf/ros2_control.xacro"/>

</robot>

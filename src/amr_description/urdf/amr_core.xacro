<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ─── Tham số kích thước (đơn vị: mét) ─────────────────────── -->
  <!-- CẦN ĐIỀU CHỈNH theo kích thước khung xe thực tế -->
  <xacro:property name="base_length"      value="0.297"/> <!-- chiều dài chassis (không tính bánh) -->
  <xacro:property name="base_width"       value="0.158"/> <!-- chiều rộng khung chassis thật (không gồm bánh) -->
  <xacro:property name="base_height"      value="0.062"/> <!-- chiều cao chassis (không tính bánh) -->
  <xacro:property name="ground_clearance" value="0.022"/> <!-- mặt đất → mặt dưới khung gầm -->
  <xacro:property name="wheel_radius"     value="0.05"/>  <!-- bán kính bánh (đường kính 100mm → r=50mm) -->
  <xacro:property name="wheel_width"      value="0.029"/> <!-- bề rộng bánh -->
  <xacro:property name="wheelbase"        value="0.21"/>  <!-- khoảng cách trục trước-sau -->
  <xacro:property name="track_width"      value="0.217"/> <!-- khoảng cách 2 tâm bánh ngang (tâm→tâm) -->
  <!-- Khoảng trống lọt lòng giữa 2 mặt trong của 2 bánh (dẫn xuất) = 0.188m -->
  <xacro:property name="wheel_inner_gap"  value="${track_width - wheel_width}"/>
  <!-- z của base_link so với base_footprint = ground_clearance + chassis_height/2 = 0.053m -->
  <xacro:property name="base_link_z"      value="${ground_clearance + base_height/2}"/>

  <!-- ─── Materials ─────────────────────────────────────────────── -->
  <material name="dark_grey">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>
  <material name="light_grey">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.0 0.4 0.8 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <!-- ─── Base footprint ────────────────────────────────────────── -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${base_link_z}" rpy="0 0 0"/>
  </joint>

  <!-- ─── Base link (chassis) ───────────────────────────────────── -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <xacro:inertial_box mass="2.0" l="${base_length}" w="${base_width}" h="${base_height}"/>
  </link>

  <!-- ─── Wheel macro (bánh sau dẫn động) ─────────────────────── -->
  <xacro:macro name="wheel" params="name x y">
    <link name="${name}_wheel">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <material name="black"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      </collision>
      <xacro:inertial_cylinder mass="0.15" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${name}_wheel"/>
      <!-- z = wheel_radius - base_link_z = 0.05 - 0.053 = -0.003m -->
      <origin xyz="${x} ${y} ${wheel_radius - base_link_z}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- ─── Steering wheel macro (bánh trước lái) ────────────────── -->
  <!-- Cấu trúc: base_link → steer_joint (revolute,z) → steer_link
                            → wheel_joint (continuous,y) → wheel    -->
  <xacro:macro name="steering_wheel" params="name x y">
    <!-- Link trung gian tại tâm bánh, chỉ mang inertia tối thiểu -->
    <link name="${name}_steer_link">
      <xacro:inertial_box mass="0.001" l="0.01" w="0.01" h="0.01"/>
    </link>

    <!-- Joint lái: revolute quanh trục Z, giới hạn ±30° -->
    <joint name="${name}_steer_joint" type="revolute">
      <parent link="base_link"/>
      <child  link="${name}_steer_link"/>
      <origin xyz="${x} ${y} ${wheel_radius - base_link_z}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.5236" upper="0.5236" effort="10.0" velocity="1.0"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <!-- Bánh trước: xoay quanh Y, parent là steer_link -->
    <link name="${name}_wheel">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <material name="black"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      </collision>
      <xacro:inertial_cylinder mass="0.15" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="${name}_steer_link"/>
      <child  link="${name}_wheel"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <!-- Bánh sau dẫn động (JGB37-520) -->
  <xacro:wheel name="rear_left"   x="${-wheelbase/2}" y="${track_width/2}"/>
  <xacro:wheel name="rear_right"  x="${-wheelbase/2}" y="${-track_width/2}"/>

  <!-- Bánh trước lái (HTS-20H) — có revolute steer_joint cho Ackermann controller -->
  <xacro:steering_wheel name="front_left"  x="${wheelbase/2}"  y="${track_width/2}"/>
  <xacro:steering_wheel name="front_right" x="${wheelbase/2}"  y="${-track_width/2}"/>

  <!-- ─── Gazebo: friction cho bánh ────────────────────────────── -->
  <!-- mu1 = hệ số ma sát tĩnh, mu2 = hệ số ma sát trượt -->
  <gazebo reference="rear_left_wheel">
    <mu1>1.0</mu1>
    <mu2>0.5</mu2>
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="rear_right_wheel">
    <mu1>1.0</mu1>
    <mu2>0.5</mu2>
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="front_left_wheel">
    <mu1>1.0</mu1>
    <mu2>0.5</mu2>
    <material>Gazebo/Black</material>
  </gazebo>
  <gazebo reference="front_right_wheel">
    <mu1>1.0</mu1>
    <mu2>0.5</mu2>
    <material>Gazebo/Black</material>
  </gazebo>

  <!-- ─── Gazebo: màu sắc các link ──────────────────────────────── -->
  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="front_left_steer_link">
    <material>Gazebo/Grey</material>
  </gazebo>
  <gazebo reference="front_right_steer_link">
    <material>Gazebo/Grey</material>
  </gazebo>

</robot>
